# Copiá este archivo como "secrets.toml" y completá tus claves.
# En Streamlit Community Cloud se cargan en: Settings -> Secrets
#
# IMPORTANTE: nunca subas secrets.toml a Git (ya está en .gitignore).
#
# REGLA TOML: todas las claves sueltas van ANTES de las secciones [tabla].

# --- Google Gemini (obligatorio) ---
GEMINI_API_KEY = "tu-api-key-de-gemini"
GEMINI_MODEL   = "gemini-2.5-flash"

# --- Supabase (opcional) ---
SUPABASE_URL = ""
SUPABASE_KEY = ""

# --- Usuarios con acceso a la app (login) ---
# Generá el hash de contraseña con: python crear_usuario.py
[usuarios.maestra]
nombre        = "Maestra Ana"
password_hash = "$2b$12$REEMPLAZA_CON_HASH_GENERADO_POR_crear_usuario.py"
